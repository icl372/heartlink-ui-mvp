# Configure these server-side values in Vercel Project Settings. Do not put real values in this file.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
# Optional browser-visible route selector only. It must never contain a provider key.
VITE_USE_REAL_AI=
# Optional browser-visible selector for the owned Supabase create route. It is not a credential.
VITE_USE_SUPABASE=
# Public share-link origin. Vite only exposes VITE_* variables in browser code.
# Use one of these names; VITE_APP_BASE_URL takes precedence over the others.
VITE_APP_BASE_URL=https://www.xygift.cn
VITE_SITE_URL=
VITE_PUBLIC_SITE_URL=
# Server-only AI cost protection. Set RATE_LIMIT_SALT only in Vercel Project Settings.
AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_WINDOW_MINUTES=10
AI_RATE_LIMIT_MAX_REQUESTS=5
AI_RATE_LIMIT_DAILY_MAX_REQUESTS=20
AI_GLOBAL_DAILY_MAX_REQUESTS=200
RATE_LIMIT_SALT=replace-with-random-server-secret
